# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pradeshiya_sabha
DB_USER=root
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@pradeshiyasabha.lk

# SMS Gateway
SMS_API_KEY=your_sms_api_key
SMS_API_URL=https://sms-gateway.lk/api/send
SMS_SENDER=PSABHA

# Payment Gateway (PayHere)
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_SECRET=your_payhere_secret
PAYHERE_URL=https://sandbox.payhere.lk/pay/checkout

# Digital Signature
SIGNATURE_PRIVATE_KEY_PATH=./keys/private.pem
SIGNATURE_PUBLIC_KEY_PATH=./keys/public.pem

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# SMS Provider (choose one: notify_lk | sms_lk | dialog | generic)
SMS_PROVIDER=notify_lk
SMS_USER_ID=your_notify_lk_user_id

# PayHere (Frontend URL for redirect after payment)
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:5000

# Socket.io (CORS — comma-separated allowed origins)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.lk

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Bootstrap Admin (seed.js — change before running on a real server)
BOOTSTRAP_ADMIN_EMAIL=admin@pradeshiyasabha.lk
BOOTSTRAP_ADMIN_NAME=System Administrator
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe@2024!

# Schema sync — set to true ONLY for initial local setup, never in production
DB_SYNC_ALTER=true

# Logging (production)
LOG_DIR=./logs
